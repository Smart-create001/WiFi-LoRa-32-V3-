#include <WiFi.h>
#include <PubSubClient.h>
#include <RadioLib.h>
#include <U8g2lib.h>

// ================= WiFi =================
const char* WiFi_SSID = "Smart";
const char* WiFi_PASS = "0123456789";

// ================= NETPIE =================
const char* MQTT_BROKER    = "mqtt.netpie.io";
const char* MQTT_CLIENTID = "7aca62d8-f6d8-4eb5-a89a-c37a998fb040";
const char* MQTT_TOKEN    = "NZ3WLHA95fFgh5sgeqXULM7n3yHb3ZSF";
const char* MQTT_SECRET  = "wKJ2rbvwTDzs49gXbbepnXv2L1mEJMNy";

// ================= Hardware =================
#define FAN_PIN        5
#define VEXT_CTRL      36
#define TEMP_THRESHOLD 30.0

// ================= MANUAL CONTROL =================
volatile int manual_mode = 0;   // 0=AUTO, 1=MANUAL
volatile int manual_pump = 0;   // 0=OFF, 1=ON

// ================= STATE =================
int pump_state = 0;             // ตัวแปรเดียวที่ใช้คุมปั๊ม

// ================= LoRa =================
SX1262 radio = new Module(8, 14, 12, 13);

// ================= OLED =================
U8G2_SSD1306_128X64_NONAME_F_HW_I2C u8g2(
  U8G2_R0, 21, 18, 17
);

// ================= SENSOR =================
float temp = 0.0;
float hum  = 0.0;
float rssi = 0.0;

WiFiClient espClient;
PubSubClient client(espClient);

// =================================================
// MQTT CALLBACK  (MANUAL override ทันที)
// =================================================
void mqttCallback(char* topic, byte* payload, unsigned int length) {
  String msg;
  for (int i = 0; i < length; i++) msg += (char)payload[i];

  Serial.println("\n===== MQTT CALLBACK =====");
  Serial.println(msg);

  if (msg.indexOf("\"manual_mode\":1") != -1) manual_mode = 1;
  if (msg.indexOf("\"manual_mode\":0") != -1) manual_mode = 0;
  if (msg.indexOf("\"manual_pump\":1") != -1) manual_pump = 1;
  if (msg.indexOf("\"manual_pump\":0") != -1) manual_pump = 0;

  // ⭐ MANUAL override ทันที
  if (manual_mode == 1) {
    pump_state = manual_pump;
    digitalWrite(FAN_PIN, pump_state ? HIGH : LOW);
    Serial.println("[CONTROL] MANUAL applied immediately");
  }

  Serial.println("=========================\n");
}

// =================================================
void setup_wifi() {
  WiFi.begin(WiFi_SSID, WiFi_PASS);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("\nWiFi Connected");
}

// =================================================
void reconnect() {
  while (!client.connected()) {
    Serial.println("[MQTT] Connecting...");
    if (client.connect(MQTT_CLIENTID, MQTT_TOKEN, MQTT_SECRET)) {
      Serial.println("[MQTT] Connected");
      client.subscribe("@shadow/data/updated");
      Serial.println("[MQTT] Subscribed to delta");
    } else {
      Serial.print("[MQTT] Failed rc=");
      Serial.println(client.state());
      delay(3000);
    }
  }
}

// =================================================
void setup() {
  Serial.begin(115200);

  pinMode(FAN_PIN, OUTPUT);
  digitalWrite(FAN_PIN, LOW);

  pinMode(VEXT_CTRL, OUTPUT);
  digitalWrite(VEXT_CTRL, LOW);
  delay(100);

  u8g2.begin();
  u8g2.setFont(u8g2_font_ncenB08_tr);

  radio.begin(923.2, 125.0, 7, 5, 0x34, 22, 8);

  setup_wifi();
  client.setServer(MQTT_BROKER, 1883);
  client.setCallback(mqttCallback);
}

// =================================================
void loop() {
  if (!client.connected()) reconnect();
  client.loop();

  // ================= AUTO MODE =================
  if (manual_mode == 0) {
    String rx;
    if (radio.receive(rx) == RADIOLIB_ERR_NONE) {
      int t = rx.indexOf("T:");
      int h = rx.indexOf(",H:");

      if (t != -1 && h != -1) {
        temp = rx.substring(t + 2, h).toFloat();
        hum  = rx.substring(h + 3).toFloat();
        rssi = radio.getRSSI();

        pump_state = (temp >= TEMP_THRESHOLD) ? 1 : 0;
        digitalWrite(FAN_PIN, pump_state ? HIGH : LOW);

        Serial.println("[CONTROL] AUTO by temperature");
      }
    }
  }

  // ================= OLED =================
  u8g2.clearBuffer();
  u8g2.setCursor(0, 15); u8g2.print("RX Controller");
  u8g2.setCursor(0, 30); u8g2.print("Temp: "); u8g2.print(temp, 1); u8g2.print(" C");
  u8g2.setCursor(0, 45); u8g2.print("Pump: "); u8g2.print(pump_state ? "ON" : "OFF");
  u8g2.setCursor(0, 60); u8g2.print("Mode: "); u8g2.print(manual_mode ? "MANUAL" : "AUTO");
  u8g2.sendBuffer();

  // ================= SHADOW REPORT =================
  String payload = "{ \"data\": {";
  payload += "\"Temperature\":" + String(temp, 1) + ",";
  payload += "\"Humidity\":" + String(hum, 1) + ",";
  payload += "\"PumpStatus\":" + String(pump_state) + ",";
  payload += "\"RSSI\":" + String(rssi);
  payload += "} }";

  client.publish("@shadow/data/update", payload.c_str());

  delay(300);
}
